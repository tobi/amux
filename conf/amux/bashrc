# amux panel shell — minimal, deterministic
bind 'set enable-bracketed-paste on' 2>/dev/null
__amux_first=1
__amux_prompt() {
  local ec=$?
  local name="${AMUX_PANEL:-amux}"
  # Skip sentinel on initial shell startup — no command has run yet.
  if [ "$__amux_first" = 1 ]; then
    __amux_first=0
  else
    if [ $ec -eq 0 ]; then
      printf '\nSUCCESS\n'
    else
      printf '\nFAIL EXITCODE:%d\n' "$ec"
    fi
  fi
  PS1="$name \\$ "
}
PROMPT_COMMAND=__amux_prompt
