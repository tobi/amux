{
  "name": "amux",
  "version": "0.1.0",
  "description": "Agentic mux — named tmux panels for AI agents and humans",
  "keywords": ["pi-package"],
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "amux": "bin/amux"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "pi": {
    "extensions": ["./ext/index.ts"],
    "skills": ["./skills"]
  },
  "files": [
    "src",
    "bin",
    "conf",
    "ext",
    "skills"
  ],
  "scripts": {
    "test": "node --experimental-strip-types --no-warnings --test test/*.test.ts",
    "test:unit": "node --experimental-strip-types --no-warnings --test test/unit.test.ts",
    "test:integration": "node --experimental-strip-types --no-warnings --test test/integration.test.ts"
  },
  "dependencies": {
    "@xterm/headless": "^6.0.0"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@sinclair/typebox": "*"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": { "optional": true },
    "@mariozechner/pi-ai": { "optional": true },
    "@sinclair/typebox": { "optional": true }
  }
}
